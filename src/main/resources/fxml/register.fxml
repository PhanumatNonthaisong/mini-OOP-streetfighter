<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="15" alignment="CENTER"
      style="-fx-background-color:#111111;"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.fightbooking.controller.RegisterController">

    <Label text="REGISTER"
           style="-fx-text-fill:#ff2e2e; -fx-font-size:28px; -fx-font-weight:bold;"/>

    <TextField fx:id="nameField"
               promptText="Name"
               maxWidth="250"
               style="-fx-background-color:#1f1f1f; -fx-text-fill:white; -fx-border-color:#ff2e2e;"/>
	
    <TextField fx:id="emailField"
               promptText="Email"
               maxWidth="250"
               style="-fx-background-color:#1f1f1f; -fx-text-fill:white; -fx-border-color:#ff2e2e;"/>

    <PasswordField fx:id="passwordField"
                   promptText="Password"
                   maxWidth="250"
                   style="-fx-background-color:#1f1f1f; -fx-text-fill:white; -fx-border-color:#ff2e2e;"/>

    <ComboBox fx:id="typeBox"
              promptText="User Type"
              maxWidth="250"/>

<TextField fx:id="studentIdField"
           promptText="Student ID (ex: 683380089-3)"
           maxWidth="250"
           visible="false"
           managed="false"
           style="-fx-background-color:#1f1f1f; -fx-text-fill:white; -fx-border-color:#ff2e2e;"/>

    <Button text="REGISTER"
            onAction="#handleRegister"
            maxWidth="250"
            style="-fx-background-color:#ff2e2e; -fx-text-fill:white;"/>

    <Button text="Back to Login"
            onAction="#goLogin"
            maxWidth="250"/>

</VBox>