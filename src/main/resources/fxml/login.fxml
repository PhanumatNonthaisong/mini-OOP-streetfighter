<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" spacing="15" style="-fx-background-color: linear-gradient(to bottom,#0f0f0f,#1a1a1a);" xmlns:fx="http://javafx.com/fxml/1" xmlns="http://javafx.com/javafx/25" fx:controller="com.fightbooking.controller.LoginController">

    <Label style="-fx-text-fill:#ff2e2e; -fx-font-size:30px; -fx-font-weight:bold;" text="FIGHT TICKET BOOKING" />

    <TextField fx:id="emailField" maxWidth="250" promptText="Email" style="-fx-background-color:#1f1f1f; -fx-text-fill:white; -fx-border-color:#ff2e2e;" />

    <PasswordField fx:id="passwordField" maxWidth="250" promptText="Password" style="-fx-background-color:#1f1f1f; -fx-text-fill:white; -fx-border-color:#ff2e2e;" />

    <Button maxWidth="250" onAction="#handleLogin" style="-fx-background-color:#ff2e2e; -fx-text-fill:white; -fx-font-weight:bold;" text="LOGIN" />

    <Hyperlink onAction="#handleRegister" style="-fx-text-fill:#ff2e2e;" text="PEEPO" />

</VBox>
